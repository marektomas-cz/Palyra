{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.palyra.dev/json/envelopes/a2ui-envelope.v1.json",
  "title": "A2UI Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "v",
    "id",
    "surface",
    "patch"
  ],
  "properties": {
    "v": {
      "const": 1
    },
    "id": {
      "$ref": "../common/canonical-id.v1.json"
    },
    "surface": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "experimental": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_id",
        "feature_flag",
        "support_summary",
        "security_review",
        "exit_criteria"
      ],
      "properties": {
        "track_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "feature_flag": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "rollout_stage": {
          "type": "string",
          "enum": [
            "disabled",
            "dark_launch",
            "operator_preview",
            "limited_preview"
          ]
        },
        "ambient_mode": {
          "type": "string",
          "enum": [
            "disabled",
            "push_to_talk"
          ]
        },
        "consent_required": {
          "type": "boolean"
        },
        "support_summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "security_review": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          }
        },
        "exit_criteria": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "ambient_mode": {
                "const": "push_to_talk"
              }
            }
          },
          "then": {
            "properties": {
              "consent_required": {
                "const": true
              }
            },
            "required": [
              "consent_required"
            ]
          }
        }
      ]
    },
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "v",
        "ops"
      ],
      "properties": {
        "v": {
          "const": 1
        },
        "ops": {
          "type": "array",
          "minItems": 1,
          "maxItems": 512,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "op",
              "path"
            ],
            "properties": {
              "op": {
                "type": "string",
                "enum": [
                  "add",
                  "replace",
                  "remove"
                ]
              },
              "path": {
                "type": "string",
                "maxLength": 512
              },
              "value": {}
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "op": {
                      "const": "remove"
                    }
                  }
                },
                "then": {
                  "not": {
                    "required": [
                      "value"
                    ]
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "op": {
                      "enum": [
                        "add",
                        "replace"
                      ]
                    }
                  }
                },
                "then": {
                  "required": [
                    "value"
                  ]
                }
              }
            ]
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_payload_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 262144
        }
      }
    }
  }
}
