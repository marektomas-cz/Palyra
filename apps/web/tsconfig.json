{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "vite/client",
      "vitest/globals"
    ]
  },
  "include": [
    "src",
    "vite.config.ts",
    "vitest.setup.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "coverage"
  ]
}
